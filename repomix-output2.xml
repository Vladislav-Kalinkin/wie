<file path="micro-exes/Makefile">
# Build PE64 micro-tests for WIE.
# Requires: x86_64-w64-mingw32-gcc (Homebrew mingw-w64).
# Clean room: freestanding micros + one ordinary CRT-linked program.

# Force mingw cross-compiler (do not use make's default CC=cc).
MINGW_CC ?= x86_64-w64-mingw32-gcc
OUT      := out
CFLAGS   := -O2 -ffreestanding -fno-stack-protector -fno-asynchronous-unwind-tables
LDFLAGS  := -nostdlib -Wl,--subsystem,console -Wl,--entry,entry
# Ordinary CRT-linked apps (independent-style): full toolchain defaults.
CRT_CFLAGS := -O2

.PHONY: all clean heap_alloc process_ids heap_core write_file read_file modules relative_path crt_hello long_loop

all: heap_alloc process_ids heap_core write_file read_file modules relative_path crt_hello long_loop

$(OUT):
	mkdir -p $(OUT)

heap_alloc: $(OUT)/heap_alloc.exe
process_ids: $(OUT)/process_ids.exe
heap_core: $(OUT)/heap_core.exe
write_file: $(OUT)/write_file.exe
read_file: $(OUT)/read_file.exe
modules: $(OUT)/modules.exe
relative_path: $(OUT)/relative_path.exe
crt_hello: $(OUT)/crt_hello.exe
long_loop: $(OUT)/long_loop.exe

$(OUT)/heap_alloc.exe: heap_alloc/main.c | $(OUT)
	$(MINGW_CC) $(CFLAGS) $(LDFLAGS) -o $@ $< -lkernel32
	@echo "built $@"

$(OUT)/process_ids.exe: process_ids/main.c | $(OUT)
	$(MINGW_CC) $(CFLAGS) $(LDFLAGS) -o $@ $< -lkernel32
	@echo "built $@"

$(OUT)/heap_core.exe: heap_core/main.c | $(OUT)
	$(MINGW_CC) $(CFLAGS) $(LDFLAGS) -o $@ $< -lkernel32
	@echo "built $@"

$(OUT)/write_file.exe: write_file/main.c | $(OUT)
	$(MINGW_CC) $(CFLAGS) $(LDFLAGS) -o $@ $< -lkernel32
	@echo "built $@"

$(OUT)/read_file.exe: read_file/main.c | $(OUT)
	$(MINGW_CC) $(CFLAGS) $(LDFLAGS) -o $@ $< -lkernel32
	@echo "built $@"

$(OUT)/modules.exe: modules/main.c | $(OUT)
	$(MINGW_CC) $(CFLAGS) $(LDFLAGS) -o $@ $< -lkernel32
	@echo "built $@"

$(OUT)/relative_path.exe: relative_path/main.c | $(OUT)
	$(MINGW_CC) $(CFLAGS) $(LDFLAGS) -o $@ $< -lkernel32
	@echo "built $@"

# Normal Windows console + CRT (UCRT api-ms-win-crt-*), not freestanding.
$(OUT)/crt_hello.exe: crt_hello/main.c | $(OUT)
	$(MINGW_CC) $(CRT_CFLAGS) -o $@ $<
	@echo "built $@"


$(OUT)/long_loop.exe: long_loop/main.c | $(OUT)
	$(MINGW_CC) $(CFLAGS) $(LDFLAGS) -o $@ $< -lkernel32
	@echo "built $@"

clean:
	rm -rf $(OUT)
</file>

<file path="scripts/run-micro-suite.sh">
#!/usr/bin/env bash
# Run all micro-EXE gates. Exit non-zero on first failure.
# Clean room suite: freestanding kernel32 micros (Microsoft Learn semantics).
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
CLI="${CLI:-$ROOT/target/release/wie-cli}"
CPU="${WIE_CPU:-jit}"

if [[ ! -x "$CLI" ]]; then
  echo "building wie-cli (release)…"
  cargo build -p wie-cli --release --manifest-path "$ROOT/Cargo.toml"
fi

make -C "$ROOT/micro-exes"

export WIE_CPU="$CPU"
echo "=== micro-suite WIE_CPU=$WIE_CPU ==="

run_one() {
  local pe="$1"
  shift
  echo "--- run-micro $pe $* ---"
  "$CLI" run-micro "$pe" "$@"
}

# N1 — no bottle required
run_one "$ROOT/micro-exes/out/process_ids.exe"
run_one "$ROOT/micro-exes/out/heap_alloc.exe"
run_one "$ROOT/micro-exes/out/heap_core.exe"
run_one "$ROOT/micro-exes/out/modules.exe"
run_one "$ROOT/micro-exes/out/long_loop.exe"

# N5 — ordinary CRT-linked hello (drives UCRT + more kernel32)
run_one "$ROOT/micro-exes/out/crt_hello.exe" --max-api 8000

# N2 — bottle v0
BOTTLE="$(mktemp -d "${TMPDIR:-/tmp}/wie-bottle.XXXXXX")"
mkdir -p "$BOTTLE/drive_c/App"
printf 'hello-n2' >"$BOTTLE/drive_c/App/n2_in.txt"
echo "bottle: $BOTTLE"

run_one "$ROOT/micro-exes/out/write_file.exe" --root "$BOTTLE"
if [[ ! -f "$BOTTLE/drive_c/App/n2_out.txt" ]]; then
  echo "FAIL: n2_out.txt not created on host" >&2
  exit 1
fi
if ! grep -q 'WIE_N2' "$BOTTLE/drive_c/App/n2_out.txt"; then
  echo "FAIL: n2_out.txt content mismatch" >&2
  exit 1
fi
echo "host write ok: $BOTTLE/drive_c/App/n2_out.txt"

run_one "$ROOT/micro-exes/out/read_file.exe" --root "$BOTTLE"

run_one "$ROOT/micro-exes/out/relative_path.exe" --root "$BOTTLE"
if [[ ! -f "$BOTTLE/drive_c/App/n2_rel_out.txt" ]]; then
  echo "FAIL: n2_rel_out.txt not created (relative path resolve)" >&2
  exit 1
fi
if ! grep -q 'REL_OK' "$BOTTLE/drive_c/App/n2_rel_out.txt"; then
  echo "FAIL: n2_rel_out.txt content mismatch" >&2
  exit 1
fi
echo "relative path write ok: $BOTTLE/drive_c/App/n2_rel_out.txt"

rm -rf "$BOTTLE"
echo "=== micro-suite: ok ==="
</file>

