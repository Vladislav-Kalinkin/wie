pub fn handle_create_compatible_bitmap(
    engine: &mut dyn wie_cpu::CpuEngine,
    state: &mut WinApiState,
) -> Result<WinApiHandlerResult> {
    let _hdc = engine
        .read_rcx()
        .context("failed to read RCX for CreateCompatibleBitmap")?;

